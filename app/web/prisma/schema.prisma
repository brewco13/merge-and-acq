generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id                           String                         @id
  legacyId                     String?                        @unique
  name                         String
  businessArea                 String?
  l1Capability                 String?
  l2Capability                 String?
  l3Capability                 String?
  description                  String?
  sourceCompany                String?
  sourceEnvironment            String?
  currentState                 String?
  criticality                  String?
  lifecycleStatus              String?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime
  DecisionCandidateApplication DecisionCandidateApplication[]
  DispositionDecision          DispositionDecision[]
  Note                         Note[]
  Ownership                    Ownership[]
  ConfidenceAssessment         ConfidenceAssessment[]

  @@index([businessArea])
  @@index([l1Capability, l2Capability, l3Capability])
  @@index([name])
}

model ConfidenceAssessment {
  id                  String                     @id @default(cuid())
  applicationId       String
  horizonType         ConfidenceHorizon
  calculatedScore     Int
  manualAdjustment    Int                        @default(0)
  finalScore          Int
  confidenceBand      ConfidenceBand
  scoringModelVersion String
  assessmentStatus    ConfidenceAssessmentStatus @default(SYSTEM_CALCULATED)

  reviewerName   String?
  reviewNotes    String?
  overrideReason String?

  isStale      Boolean   @default(false)
  calculatedAt DateTime
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Application           Application             @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  ConfidenceFactorScore ConfidenceFactorScore[]

  @@unique([applicationId, horizonType])
  @@index([applicationId])
  @@index([horizonType, finalScore])
  @@index([confidenceBand])
}

model ConfidenceFactorScore {
  id                     String               @id @default(cuid())
  confidenceAssessmentId String
  factorCode             ConfidenceFactorCode
  rawScore               Int
  weightPercent          Decimal              @db.Decimal(5, 2)
  weightedScore          Decimal              @db.Decimal(6, 2)
  maxScore               Int                  @default(100)
  explanation            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ConfidenceAssessment ConfidenceAssessment @relation(fields: [confidenceAssessmentId], references: [id], onDelete: Cascade)

  @@unique([confidenceAssessmentId, factorCode])
  @@index([factorCode])
}

model DecisionCandidateApplication {
  id                     String              @id
  decisionId             String
  candidateApplicationId String
  priorityOrder          Int?
  notes                  String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime
  Application            Application         @relation(fields: [candidateApplicationId], references: [id])
  DispositionDecision    DispositionDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@unique([decisionId, candidateApplicationId])
  @@index([candidateApplicationId])
  @@index([decisionId])
}

model DispositionDecision {
  id                           String                         @id
  applicationId                String
  decisionHorizon              DecisionHorizon
  targetDate                   DateTime?
  targetDisposition            DispositionType?
  status                       DecisionStatus                 @default(DRAFT)
  businessReviewStatus         ReviewStatus?                  @default(NOT_STARTED)
  businessSignoffStatus        ReviewStatus?                  @default(NOT_STARTED)
  technicalReviewStatus        ReviewStatus?                  @default(NOT_STARTED)
  technicalSignoffStatus       ReviewStatus?                  @default(NOT_STARTED)
  reviewedAt                   DateTime?
  targetPlatform               String?
  targetTimeline               String?
  rationale                    String?
  decisionDate                 DateTime?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime
  DecisionCandidateApplication DecisionCandidateApplication[]
  Application                  Application                    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  Note                         Note[]

  @@unique([applicationId, decisionHorizon, targetDate])
  @@index([applicationId])
  @@index([decisionHorizon])
  @@index([status])
}

model Ownership {
  id                     String      @id
  applicationId          String
  businessOwner          String?
  technicalOwner         String?
  businessDecisionOwner  String?
  technicalDecisionOwner String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime
  Application            Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

enum DecisionHorizon {
  TSA_EXPIRATION
  LONG_TERM
}

enum DecisionStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  IMPLEMENTED
}

enum DispositionType {
  RETAIN
  RETIRE
  REPLACE
  REHOST
  REPLATFORM
  REPURCHASE
  CONSOLIDATE
}

enum NoteLevel {
  APPLICATION
  DECISION
}

enum ReviewStatus {
  NOT_STARTED
  IN_PROGRESS
  REVIEWED
  SIGNED_OFF
}

enum ConfidenceHorizon {
  TSA
  LONG_TERM
}

enum ConfidenceBand {
  LOW
  MEDIUM
  HIGH
}

enum ConfidenceAssessmentStatus {
  SYSTEM_CALCULATED
  REVIEWED
  APPROVED
  OVERRIDDEN
}

enum ConfidenceFactorCode {
  DISPOSITION_DEFINITION
  EVIDENCE_QUALITY
  BUSINESS_ALIGNMENT
  TECHNICAL_ALIGNMENT
  EXECUTION_READINESS
  STABILITY_CONSISTENCY
}

model Note {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  content               String
  source                String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  dispositionDecision   DispositionDecision? @relation(fields: [dispositionDecisionId], references: [id])
  dispositionDecisionId String?
}
